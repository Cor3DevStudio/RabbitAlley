# Copy to .env and set your MySQL connection (HeidiSQL / MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=rabbit_alley_pos

# Optional: port for API server (default 3001)
PORT=3001

# Thermal Printer — USB or Ethernet + ESC/POS
# PRINTER_TYPE: epson = ESC/POS (default; USB/Ethernet thermal printers)
#   Other: star, brother, daruma, tanca
# PRINTER_INTERFACE:
#   - Automatic USB (no click): printer:ExactPrinterName (requires Node 18 or 20 + npm install printer --legacy-peer-deps)
#   - Leave empty → use browser «Print receipt» (select printer in dialog)
#   - Ethernet: tcp://192.168.1.100:9100
#   - Linux USB: /dev/usb/lp0
# PRINTER_TIMEOUT: socket timeout in ms for network printers (default 10000)
PRINTER_TYPE=epson
PRINTER_INTERFACE=
PRINTER_TIMEOUT=10000
