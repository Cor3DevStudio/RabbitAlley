# Copy to .env and set your MySQL connection (HeidiSQL / MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=rabbit_alley_pos

# Optional: port for API server (default 3001)
PORT=3001

# Thermal Printer — USB or Ethernet + ESC/POS
# PRINTER_TYPE: epson = ESC/POS (default; USB/Ethernet thermal printers)
#   Other: star, brother, daruma, tanca
# PRINTER_INTERFACE: one or more printers (comma-separated for multiple)
#   - Leave empty → use browser «Print receipt» or printers added in Settings/DB
#   - Ethernet (one): tcp://192.168.1.100:9100
#   - Ethernet (many): tcp://192.168.1.1:9100,tcp://192.168.1.2:9100
#   - USB (Windows): printer:ExactPrinterName (requires npm install printer --legacy-peer-deps)
#   - Linux USB: /dev/usb/lp0
# You can also add printers in the system (Settings or DB table printers); they appear in the dropdown.
# PRINTER_TIMEOUT: socket timeout in ms for network printers (default 10000)
PRINTER_TYPE=epson
PRINTER_INTERFACE=
PRINTER_TIMEOUT=10000
