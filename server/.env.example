# Copy to .env and set your MySQL connection (HeidiSQL / MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=rabbit_alley_pos

# Optional: port for API server (default 8000)
PORT=8000

# Thermal Printer — LAN (network) or USB, ESC/POS
# PRINTER_TYPE: epson = ESC/POS (works for XPrinter and most thermal on LAN)
#
# LAN printers (recommended): one IP per printer, comma-separated for 3 areas (Lounge, Club, LD).
# Use port 9100. Get each printer's IP from its menu or your router.
# Example — one printer:   PRINTER_INTERFACE=tcp://192.168.1.100:9100
# Example — three printers: PRINTER_INTERFACE=tcp://192.168.1.101:9100,tcp://192.168.1.102:9100,tcp://192.168.1.103:9100
# Then in POS Settings assign each "Ethernet (IP:9100)" to Lounge, Club, or LD.
#
# USB: leave PRINTER_INTERFACE empty and use "Print receipt" after payment to choose printer in the dialog.
# PRINTER_TIMEOUT: socket timeout in ms for LAN printers (default 10000)
PRINTER_TYPE=epson
PRINTER_INTERFACE=
PRINTER_TIMEOUT=10000
